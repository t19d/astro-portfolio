---
import "./MainHero.css";
---

<section id="top" class="no-text-select">
	<article class="hero-content">
		<div class="hero-badge">
			<span class="status-dot"></span>
			<span>Disponible para nuevos proyectos</span>
		</div>

		<div class="me-title">
			<h1>David <span class="gradient-text">Tojo</span></h1>
			<p class="subtitle">Desarrollador Full Stack</p>
			<p class="hero-description">
				Creo experiencias web modernas, eficientes y con atención al detalle.
				Especializado en <span class="accent">Angular</span>, <span class="accent">React</span> y <span class="accent">Node.js</span>.
			</p>
		</div>

		<div class="links">
			<a
				href="https://www.linkedin.com/in/david-tojo-yebra/"
				target="_blank"
				rel="noopener"
				title="Perfil de LinkedIn de David Tojo"
				class="btn all-round"
				aria-label="LinkedIn"
			>
				<img src="assets/icons/linkedin.svg" alt="LinkedIn" />
			</a>
			<a
				href="https://github.com/t19d"
				target="_blank"
				rel="noopener"
				title="Perfil de GitHub de David Tojo"
				class="btn all-round"
				aria-label="GitHub"
			>
				<img src="assets/icons/github.svg" alt="GitHub" />
			</a>
			<a
				href="mailto:proyectostoyedev@gmail.com"
				title="Enviar correo electrónico"
				class="btn all-round"
				aria-label="Email"
			>
				<img src="assets/icons/email.svg" alt="Email" />
			</a>
		</div>
	</article>

	<div class="scroll-indicator">
		<div class="mouse">
			<div class="wheel"></div>
		</div>
	</div>
</section>
