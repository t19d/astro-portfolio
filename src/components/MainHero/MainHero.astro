---
import "./MainHero.css";
---

<section id="top" class="no-text-select">
	<article class="hero-content" role="presentation">
		<div class="hero-badge" aria-label="Desarrollador apasionado por la tecnología">
			<span class="status-dot" aria-hidden="true"></span>
			<span>Apasionado por la tecnología</span>
		</div>

		<div class="me-title">
			<h1>David <span class="gradient-text">Tojo</span></h1>
			<p class="subtitle">Desarrollador Full Stack</p>
			<p class="hero-description">
				Creo experiencias web modernas, eficientes y con atención al detalle.
				Especializado en <span class="accent">Angular</span>, <span class="accent">React</span> y <span class="accent">Node.js</span>.
			</p>
		</div>

		<nav class="links" aria-label="Redes sociales">
			<a
				href="https://www.linkedin.com/in/david-tojo-yebra/"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Perfil de LinkedIn de David Tojo"
				class="btn all-round"
			>
				<img src="assets/icons/linkedin.svg" alt="" aria-hidden="true" width="24" height="24" loading="eager" />
			</a>
			<a
				href="https://github.com/t19d"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Perfil de GitHub de David Tojo"
				class="btn all-round"
			>
				<img src="assets/icons/github.svg" alt="" aria-hidden="true" width="24" height="24" loading="eager" />
			</a>
			<a
				href="mailto:proyectostoyedev@gmail.com"
				aria-label="Enviar correo electrónico a David Tojo"
				class="btn all-round"
			>
				<img src="assets/icons/email.svg" alt="" aria-hidden="true" width="24" height="24" loading="eager" />
			</a>
		</nav>
	</article>

	<div class="scroll-indicator">
		<div class="mouse">
			<div class="wheel"></div>
		</div>
	</div>
</section>
