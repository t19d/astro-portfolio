---

<section id="experience">
	<header class="reveal">
		<span class="section-tag">Trayectoria</span>
		<h2 class="title-section">Experiencia</h2>
	</header>

	<div class="timeline">
		{
			experiences.map((exp, index) => (
				<article class={`timeline-item reveal reveal-delay-${(index % 4) + 1}`}>
					<div class="timeline-marker">
						<div class="marker-dot" />
						{index < experiences.length - 1 && <div class="marker-line" />}
					</div>

					<div class="timeline-card glass-card">
						<div class="card-header">
							<Image src={exp.logo} alt={`Logo de ${exp.company}`} class="company-logo" width={52} height={52} loading="lazy" />
							<div class="card-title">
								<h3>{exp.role}</h3>
								<div class="card-meta">
									<span class="company-name">{exp.company}</span>
									<span class="period">{exp.period}</span>
								</div>
							</div>
						</div>

						<p class="card-description">{exp.description}</p>

						<ul class="task-list">
							{exp.tasks.map((task) => (
								<li>{task}</li>
							))}
						</ul>
					</div>
				</article>
			))
		}
	</div>
</section>
