---
import "./ProjectsSection.css";

const projects = [
	{
		title: "Remove Background",
		description: "Herramienta de eliminación de fondos con IA que funciona completamente en el navegador. Sin subida de datos, 100% local, usando el modelo RMBG-1.4 y Transformers.js.",
		tags: ["WebGPU", "IA", "Transformers.js", "Privacidad"],
		link: "https://rm-bg.dty.es/",
	},
];
---

<section id="projects">
	<header class="reveal">
		<span class="section-tag">Trabajo reciente</span>
		<h2 class="title-section">Proyectos</h2>
	</header>

	<div class="projects-grid">
		{projects.map((project, index) => (
			<a
				href={project.link}
				target="_blank"
				rel="noopener noreferrer"
				class={`project-card glass-card reveal reveal-delay-${index + 1}`}
				aria-label={`Ver proyecto: ${project.title}`}
			>
				<div class="project-content">
					<div class="project-header">
						<h3>{project.title}</h3>
						<svg class="arrow-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M7 17L17 7" />
							<path d="M7 7h10v10" />
						</svg>
					</div>
					<p>{project.description}</p>
					<ul class="tags">
						{project.tags.map((tag) => (
							<li>{tag}</li>
						))}
					</ul>
				</div>
			</a>
		))}
	</div>
</section>