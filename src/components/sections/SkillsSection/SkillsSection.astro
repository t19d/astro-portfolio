---
import "./SkillsSection.css";

const skillGroups = [
	{
		title: "Frontend",
		skills: [
			{ icon: "angular.svg", name: "Angular" },
			{ icon: "react.svg", name: "React" },
			{ icon: "next.svg", name: "Next.js", invert: true },
			{ icon: "astro.svg", name: "Astro", invert: true },
			{ icon: "typescript.svg", name: "TypeScript" },
			{ icon: "js.svg", name: "JavaScript" },
			{ icon: "html-5.svg", name: "HTML5" },
			{ icon: "css-3.svg", name: "CSS3" },
			{ icon: "sass.svg", name: "Sass" },
			{ icon: "ionic.svg", name: "Ionic" },
		],
	},
	{
		title: "Backend",
		skills: [
			{ icon: "node.svg", name: "Node.js" },
			{ icon: "express.svg", name: "Express.js", invert: true },
			{ icon: "spring.svg", name: "Spring" },
			{ icon: "java.svg", name: "Java" },
			{ icon: "python.svg", name: "Python" },
			{ icon: "flask.svg", name: "Flask", invert: true },
			{ icon: "php.svg", name: "PHP" },
		],
	},
	{
		title: "Herramientas & Otros",
		skills: [
			{ icon: "git.svg", name: "Git" },
			{ icon: "github-icon.svg", name: "GitHub", invert: true },
			{ icon: "docker.svg", name: "Docker" },
			{ icon: "figma.svg", name: "Figma" },
			{ icon: "mongo.svg", name: "MongoDB" },
			{ icon: "mysql.svg", name: "MySQL" },
			{ icon: "mariadb.svg", name: "MariaDB" },
			{ icon: "linux-tux.svg", name: "Linux" },
			{ icon: "vs-code.svg", name: "VSCode" },
			{ icon: "wordpress.svg", name: "WordPress" },
			{ icon: "prestashop.svg", name: "PrestaShop" },
			{ icon: "stripe.svg", name: "Stripe" },
			{ icon: "unity.svg", name: "Unity", invert: true },
			{ icon: "android.svg", name: "Android" },
		],
	},
];
---

<section id="skills">
	<header class="reveal">
		<span class="section-tag">Stack tecnológico</span>
		<h2 class="title-section">Habilidades</h2>
	</header>

	<div class="technologies">
		{skillGroups.map((group, gIndex) => (
			<article class={`skill-group glass-card reveal reveal-delay-${gIndex + 1}`}>
				<h3>{group.title}</h3>

				<ul>
					{group.skills.map((skill) => (
						<li>
							<div class={`skill-icon ${skill.invert ? 'invert-icon' : ''}`}>
								<img src={`assets/icons/${skill.icon}`} alt={skill.name} loading="lazy" />
							</div>
							<span class="skill-name">{skill.name}</span>
						</li>
					))}
				</ul>
			</article>
		))}
	</div>
</section>
