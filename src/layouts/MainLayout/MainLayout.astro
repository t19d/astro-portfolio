---
interface Props {
	title?: string;
	baseUrl?: string;
}

const { title = "David Tojo — Desarrollador Full Stack", baseUrl = "https://portfolio.dty.es" } = Astro.props;
const description = "Portfolio de David Tojo Yebra. Desarrollador Full Stack con experiencia en Angular, React, Node.js y más. Apasionado por crear experiencias web modernas y eficientes.";
---

<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<style is:global>
			@import "@styles/buttons.css";
			@import "@styles/colors.css";
			@import "@styles/fonts.css";
			@import "@styles/links.css";
			@import "@styles/resets.css";
			@import "@styles/animations.css";

			@import "./MainLayout.css";
		</style>
		<meta name="description" content={description} />
		<meta name="author" content="David Tojo Yebra" />
		<meta name="theme-color" content="#0a0a0f" />

		<!-- Preconnect Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" />
		</noscript>

		<!-- Facebook / Open Graph -->
		<meta property="og:url" content={baseUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content="David Tojo — Desarrollador Full Stack" />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="David Tojo" />
		<meta property="og:image" content={`${baseUrl}/assets/img/me-without-bg.png`} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="David Tojo — Desarrollador Full Stack" />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:url" content={baseUrl} />
		<meta name="twitter:image" content={`${baseUrl}/assets/img/me-without-bg.png`} />

		<link rel="canonical" href={baseUrl} />
		<title>{title}</title>
		<link rel="icon" type="image/png" href={`${baseUrl}/assets/img/me-without-bg.png`} sizes="64x64" />
	</head>
	<body>
		<a href="#main-content" class="skip-to-content">Ir al contenido principal</a>
		<slot />
	</body>
</html>
