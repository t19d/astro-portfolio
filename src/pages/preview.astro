---
import MainLayout from "@layouts/MainLayout/MainLayout.astro";
---

<style>
	main {
		--dark-gold: #e7a33e;
		--light-gold: #fadbaa;

		display: grid;
		place-content: center;
		height: 100dvh;

		section {
			/* TEMPORAL */
			background: linear-gradient(to bottom, #fce3bd, #fff);
			border: 1px solid #333333;
			border-radius: 16px;
			box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
			padding: 24px;
			margin: auto;

			.image {
				position: relative;
				display: flex;
				justify-content: center;
				align-items: center;
				width: 100%;

				& .border {
					position: absolute;
					background: linear-gradient(-45deg, var(--dark-gold), var(--light-gold), var(--dark-gold));
					width: 100%;
					height: 100%;
					border-radius: 50%;
				}

				& img {
					z-index: 1;
					max-width: 400px;
					border-radius: 50%;
					padding: 10px;
					/* border: 10px solid #d29134; */

					@media (max-width: 768px) {
						width: 75%;
					}
				}
			}
		}
	}
</style>

<MainLayout>
	<main>
		<section>
			<article class="image">
				<div class="border"></div>
				<img src="assets/img/me-white.jpeg" loading="lazy" alt="David Tojo" />
			</article>

			<article class="links">
				<ul>
					<li>
						<a
							href="https://www.linkedin.com/in/david-tojo-yebra-581533176/"
							target="_blank"
							rel="noopener"
							title="Perfil de LinkedIn de David Tojo"
						>
							<img src="assets/icons/linkedin.svg" alt="LinkedIn" />
						</a>
					</li>
					<li>
						<a href="https://github.com/t19d" target="_blank" rel="noopener" title="Perfil de GitHub de David Tojo">
							<img src="assets/icons/github.svg" alt="GitHub" />
						</a>
					</li>
					<li>
						<a href="mailto:proyectostoyedev@gmail.com" title="Enviar correo electrónico a David Tojo">
							<img src="assets/icons/email.svg" alt="Correo electrónico" />
						</a>
					</li>
				</ul>
			</article>
		</section>
	</main>
</MainLayout>
